  "keyFeatures": [
    "Interactive Microsoft Graph API query editor with syntax highlighting",
    "Sample queries library covering common API scenarios",
    "OAuth 2.0 authentication with Microsoft account sign-in",
    "Request history tracking and replay",
    "Response viewer with JSON formatting and Adaptive Cards rendering",
    "Granular permission consent management",
    "Support for beta and v1.0 API endpoints",
    "Postman collection export for offline use",
    "Sovereign cloud support (GCC, DoD, China)"
  ],
  "publicApiSurface": [
